# ─────────────────────────────────────────────────────────────
# HRCE — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret
DEBUG=true

# ─── Backend ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hrce
POSTGRES_USER=hrce_user
POSTGRES_PASSWORD=hrce_password
DATABASE_URL=postgresql+asyncpg://hrce_user:hrce_password@localhost:5432/hrce

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── MinIO (Object Storage) ───────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=hrce-documents
MINIO_SECURE=false

# ─── AI / LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama3-8b-8192

# ─── LangSmith (Observability) ────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_PROJECT=hrce-dev

# ─── Agent Service ────────────────────────────────────────────
AGENT_SERVICE_HOST=localhost
AGENT_SERVICE_PORT=8001

# ─── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS (Stage 11) ──────────────────────────────────────────
# JSON array of allowed origins. Add your production domain here.
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Frontend / Next.js (Stage 12) ────────────────────────────
# Baked into the Next.js build at docker build time.
# This is the PUBLIC URL the browser uses to reach the backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

